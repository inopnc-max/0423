# Supabase Configuration Template
# Copy this file to .env.local and fill in your actual values.
# .env.local is NOT committed to GitHub (see .gitignore).

# Supabase Project URL
# You can paste either the project URL or the REST URL (.../rest/v1).
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co

# Preferred public client key for browser/server-auth usage
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Legacy anon/public JWT (supported as a fallback)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Supabase Secret Key (NEVER expose in browser/client-side code)
SUPABASE_SECRET_KEY=sb_secret_xxx

# Legacy fallback for older projects
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
